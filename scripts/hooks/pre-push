#!/usr/bin/env bash
# Pre-push hook: run unit + integration tests before any push leaves the box.
# Bypass with `git push --no-verify` when you really need to (e.g. WIP branch
# without op fixtures available).
set -euo pipefail

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

echo "pre-push: running 'make test-all' (heads up: integration tests trigger biometric prompts)"
if ! make test-all; then
	echo
	echo "pre-push: tests failed — push aborted." >&2
	echo "         bypass with 'git push --no-verify' if you must." >&2
	exit 1
fi
